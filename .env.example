# Mobility Control Tower local environment template.
# Values below are development/demo defaults. Do not reuse demo credentials for production-style profiles.

# core
GTFS_SOURCE=tisseo
LOG_LEVEL=INFO
MCT_LOG_FORMAT=json
MCT_STORAGE_BACKEND=local
MCT_STORAGE_ROOT=data
MCT_CONFIG_PATH=config/sources.yml

# storage
MCT_SERVING_ROOT=/app/data/serving
MCT_HISTORY_ROOT=/app/data/realtime_history
MCT_WATERMARK_ROOT=/app/data/watermarks
MCT_QUALITY_ROOT=/app/data/quality

# Airflow
AIRFLOW_PORT=8080
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_WEBSERVER_SECRET_KEY=local-demo-secret-key

# PostgreSQL local-demo credentials
AIRFLOW_DB_USER=mct_airflow
AIRFLOW_DB_PASSWORD=mct_airflow_demo
AIRFLOW_DB_NAME=airflow
MCT_DB_USER=mct_app
MCT_DB_PASSWORD=mct_app_demo
MCT_DB_NAME=mct_app
MCT_INCIDENT_BACKEND=postgres
MCT_INCIDENT_DATABASE_URL=postgresql://mct_app:mct_app_demo@postgres:5432/mct_app

# realtime cadence
MCT_COLLECTION_INTERVAL_SECONDS=60
MCT_REFRESH_INTERVAL_SECONDS=600
MCT_INCREMENTAL_LOOKBACK_COUNT=1

# serving
API_PORT=8000
DASHBOARD_PORT=8501
MCT_AUTH_SECRET=local-demo-change-me
MCT_TOKEN_EXPIRY_SECONDS=900
MCT_CORS_ALLOWED_ORIGINS=http://localhost:8501,http://localhost:8000

# observability
MCT_METRICS_PORT=9108
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
MCT_LINEAGE_ENABLED=false
MCT_LINEAGE_BACKEND=local_file

# production deployment
MCT_ENV=local
MCT_PUBLIC_HOSTNAME=
TLS_EMAIL=

# optional live-data mode
MCT_LIVE_GTFS_RT_URL=

# optional S3 settings for non-local experiments
MCT_S3_BUCKET=
MCT_S3_PREFIX=mobility-control-tower
MCT_AWS_REGION=eu-west-3
