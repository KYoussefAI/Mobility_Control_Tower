# Mobility Control Tower environment template.
# Copy to .env before running docker compose.

# GTFS source id from config/sources.yml.
GTFS_SOURCE=tisseo

# FastAPI host port exposed by docker compose.
API_PORT=8000

# Streamlit dashboard host port exposed by docker compose.
DASHBOARD_PORT=8501

# Airflow webserver host port exposed by docker compose.
AIRFLOW_PORT=8080

# Historical GTFS-Realtime polling interval in seconds.
POLLING_INTERVAL=30

# DuckDB file used by the API container.
DUCKDB_PATH=/app/data/serving/tisseo/2026-07-17_160355/mobility_control_tower.duckdb

# Parsed historical GTFS-Realtime Parquet root.
HISTORY_PATH=/app/data/realtime_history

# Application log level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Storage backend selected by typed settings: local or s3.
MCT_STORAGE_BACKEND=local

# Local storage root used by the storage abstraction.
MCT_STORAGE_ROOT=data

# S3 bucket used when MCT_STORAGE_BACKEND=s3.
MCT_S3_BUCKET=

# Optional S3 key prefix used when MCT_STORAGE_BACKEND=s3.
MCT_S3_PREFIX=mobility-control-tower

# AWS region used by boto3 in S3 mode.
MCT_AWS_REGION=eu-west-3

# Initial local Airflow admin account.
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
